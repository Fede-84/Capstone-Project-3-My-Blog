<%- include("partials/header") %>
    <div class="fullpost-container">
        <article class="post">
            <h2>
                <%= post.title %>
            </h2>
            <p>
                <%= post.content %>
            </p>
            <div class="post-metadata-wrapper">
                <p class="name-flag">
                    <span class="name">
                        <%= post.name %>
                    </span>
                    <span class="flag" title="<%= post.country %>">
                        <%= post.flag %>
                    </span>
                </p>
                <div class="date-and-buttons">
                    <span class="date-text">
                        Posted on:
                        <span class="date"
                            data-date="<%= post.updatedAt.getTime() > post.createdAt.getTime() ? post.updatedAt : post.createdAt %>"></span>
                    </span>
                    <div class="edit-delete-btns">
                        <a href="/editPost/<%= post.id %>" class="edit-post-btn">✏️</a>
                        <button type="button" data-id="<%= post.id %>" class="delete-post-btn">🗑️</button>
                    </div>
                </div>
            </div>
        </article>
    </div>

    <!-- Delete Modal (copy exactly from index.ejs) -->
    <div id="delete-Modal" class="overlay-modal">
        <div class="modal-content">
            <p>Are you sure you want to delete this post?</p>
            <div class="modal-buttons">
                <form id="delete-form" method="POST" action="">
                    <button type="button" id="delete-post-button">Yes</button>
                </form>
                <button type="button" id="close-modal-button">No</button>
            </div>
        </div>
    </div>

    <%- include("partials/dateFormatter") %>
        <%- include("partials/deletePost") %>